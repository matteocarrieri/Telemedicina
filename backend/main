from fastapi import FastAPI, HTTPException, Depends
from fastapi.middleware.cors import CORSMiddleware
from sqlalchemy.orm import Session
from datetime import datetime
from backend.database import SessionLocal, Animal, VitalSign
from pydantic import BaseModel

app = FastAPI()

# CORS (per frontend)
app.add_middleware(
    CORSMiddleware,
    allow_origins=["*"],
    allow_methods=["*"],
    allow_headers=["*"],
)

# Modelli Pydantic per i dati in ingresso
class AnimalCreate(BaseModel):
    name: str
    species: str
    owner_name: str
    owner_phone: str

class VitalSignCreate(BaseModel):
    animal_id: int
    temperature: float
    heart_rate: int
    symptoms: str

# Dependency per il DB
def get_db():
    db = SessionLocal()
    try:
        yield db
    finally:
        db.close()

# Endpoints
@app.post("/animals/")
def create_animal(animal: AnimalCreate, db: Session = Depends(get_db)):
    db_animal = Animal(**animal.dict())
    db.add(db_animal)
    db.commit()
    db.refresh(db_animal)
    return db_animal

@app.post("/vitals/")
def record_vitals(vitals: VitalSignCreate, db: Session = Depends(get_db)):
    db_vitals = VitalSign(**vitals.dict())
    db.add(db_vitals)
    db.commit()
    db.refresh(db_vitals)
    
    # Alert se temperatura troppo alta
    if vitals.temperature > 39.0:
        return {"status": "warning", "message": "Febbre alta rilevata!"}
    
    return {"status": "ok", "data": db_vitals}

@app.get("/vitals/{animal_id}")
def get_vitals(animal_id: int, db: Session = Depends(get_db)):
    vitals = db.query(VitalSign).filter(VitalSign.animal_id == animal_id).all()
    if not vitals:
        raise HTTPException(status_code=404, detail="Nessun dato trovato")
    return vitals
